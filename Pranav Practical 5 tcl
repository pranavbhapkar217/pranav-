CREATE DATABASE IF NOT EXISTS tcl_practical;
USE tcl_practical;


DROP TABLE IF EXISTS accounts;
CREATE TABLE accounts (
    id INT PRIMARY KEY,
    name VARCHAR(50),
    balance INT
);

INSERT INTO accounts VALUES
(1, 'Amit', 5000),
(2, 'Ravi', 3000),
(3, 'Neha', 2000);

SELECT * FROM accounts;


SET autocommit = 0;

START TRANSACTION;

UPDATE accounts 
SET balance = balance - 1000 
WHERE id = 1;

SAVEPOINT sp1;

UPDATE accounts 
SET balance = balance + 1000 
WHERE id = 2;

SELECT * FROM accounts;

ROLLBACK TO sp1;

SELECT * FROM accounts;

COMMIT;

SELECT * FROM accounts;
